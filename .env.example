# Copy to .env.local and fill in values.

# --- Clerk (https://dashboard.clerk.com → API Keys) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Supabase (https://supabase.com/dashboard → your project → Project Settings → API) ---
# Project URL (public — safe to expose; used by the server client only in this app)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# service_role secret — server-only; bypasses RLS. Never use in the browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=your_api_key_here

# --- SendGrid (optional until email routes are used) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
